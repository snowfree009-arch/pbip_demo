	measure 'OpCo Previous Year Current Week Revenue' = ```
			
			CALCULATE(
			    SUM('agg agg_revenue_call_report_revenue'[Revenue]),
			    DATESBETWEEN(
			        'agg agg_revenue_call_report_revenue'[Reporting Date],
			        TODAY() - WEEKDAY(TODAY(), 2) + 1 - 365,
			        TODAY() - WEEKDAY(TODAY(), 2) + 7 - 365
			    )
			)
			
