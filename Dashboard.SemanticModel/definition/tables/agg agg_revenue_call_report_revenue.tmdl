			                    IF('agg agg_revenue_call_report_revenue'[is_impounded] = "no"
			                    && 'agg agg_revenue_call_report_revenue'[Lock Status] = "yes" 
			                    && 'agg agg_revenue_call_report_revenue'[Audit Status] = "yes" 
