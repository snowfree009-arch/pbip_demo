			"Previous Year Current (" & 
			FORMAT(
			    TODAY() - WEEKDAY(TODAY(), 2) + 1 - 365, 
			    "MM/DD/YYYY"
			) & 
			" - " & 
			FORMAT(
			    TODAY() - WEEKDAY(TODAY(), 2) + 7 - 365, 
			    "MM/DD/YYYY"
			) & 
			")"
			
			```
		lineageTag: 30619928-00dd-418e-839c-058007759a4b

	measure CurrentMonthRange = ```
			
			"Current (" &
			FORMAT(DATE(YEAR(TODAY()), MONTH(TODAY()), 1), "MM/DD/YYYY") & "-" &
			FORMAT(EOMONTH(TODAY(), 0), "MM/DD/YYYY") & ")"
			
			```
		lineageTag: 1762aaf8-691f-457a-877e-59f0d753bb2d

	measure LastMonthRange = ```
			
			"Last (" & 
			FORMAT(DATE(
			    IF(MONTH(TODAY()) = 1, YEAR(TODAY()) - 1, YEAR(TODAY())), 
			    IF(MONTH(TODAY()) = 1, 12, MONTH(TODAY()) - 1), 
			    1
			), "MM/DD/YYYY") & 
			" - " & 
			FORMAT(EOMONTH(TODAY(), -1), "MM/DD/YYYY") & 
			")"
			
			```
		lineageTag: e3dcb162-9a32-4c0c-ab37-c17151ef4e5b

	measure PreviousYearCurrentMonthRange = ```
			
			"Previous Year Current (" &
			FORMAT(DATE(YEAR(TODAY()) - 1, MONTH(TODAY()), 1), "MM/DD/YYYY") & " - " &
			FORMAT(EOMONTH(TODAY(), -12), "MM/DD/YYYY") & ")"
			
			```
		lineageTag: ef3eb1dd-d284-4a6d-9bcb-40bdfc892f3a

	measure Tows(#)_new =
			
			var _include_zero_revenue = IF(
			    SELECTEDVALUE(ZeroRevenueFlag[Label]) = "Exclude Zero Revenue",
			    "No", "Yes"
			)
			
			return
			IF(
			    _include_zero_revenue="Yes",
			    DISTINCTCOUNT('agg agg_revenue_call_report_revenue'[call_id_sk]),
			    CALCULATE(DISTINCTCOUNT('agg agg_revenue_call_report_revenue'[call_id_sk]),
			       agg_revenue_call_report[Is Zero Revenue Call] = "No"
			    )
			)
		formatString: 0
		lineageTag: b033e392-983d-415a-a2e4-2a088d36f3d1

	measure call_type_label = ```
			
			VAR SelectedValues = VALUES('agg agg_revenue_call_report_revenue'[Call Type])
			VAR SelectedCount = COUNTROWS(SelectedValues)
			VAR TotalCount = COUNTROWS(ALL('agg agg_revenue_call_report_revenue'[Call Type]))
			RETURN
			    IF(
			        SelectedCount = 0 || SelectedCount = TotalCount,
			        "Standard Calls, Impound Calls",
			        IF(
			            SelectedCount = 1,
			            CONCATENATEX(SelectedValues, 'agg agg_revenue_call_report_revenue'[Call Type], ", "),
			            CONCATENATEX(SelectedValues, 'agg agg_revenue_call_report_revenue'[Call Type], ", ")
			        )
			    )
			
			```
		lineageTag: 4a98a359-ea39-49ef-b720-2e9b0e4575a1

