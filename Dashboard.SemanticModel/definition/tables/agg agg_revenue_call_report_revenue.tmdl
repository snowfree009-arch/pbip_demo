	measure 'OpCo Current Month Revenue' = ```
			
			CALCULATE(
			    SUM('agg agg_revenue_call_report_revenue'[Revenue]),
			    MONTH('agg agg_revenue_call_report_revenue'[Reporting Date]) = MONTH(TODAY()) &&
			    YEAR('agg agg_revenue_call_report_revenue'[Reporting Date]) = YEAR(TODAY())
			) 
			
