			    ISFILTERED('agg agg_revenue_call_report_payments'[Payment Date]),
			    CONCATENATE(min('agg agg_revenue_call_report_payments'[Payment Date]), "-"&max('agg agg_revenue_call_report_payments'[Payment Date])),
