table 'agg agg_revenue_call_report_payments'
	lineageTag: 6e00923f-3a44-439c-b8cc-d66a758d2e89

	measure DepositAmount = sum('agg agg_revenue_call_report_payments'[payment_amount])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 91b9eb0e-d746-48af-9dba-04ac67ee97d6

	measure dxm_PaymentDeposits = sum('agg agg_revenue_call_report_payments'[payment_amount])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: a370a138-560b-42c1-8bd7-ccfc544df927

	measure dxm_PaymentDateFilters =
			
			"Payment Date: " & IF(
			    ISFILTERED('agg agg_revenue_call_report_payments'[Payment Date]),
			    CONCATENATE(format(min('agg agg_revenue_call_report_payments'[Payment Date]),"mm/dd/yyyy"), "-"& format(max('agg agg_revenue_call_report_payments'[Payment Date]),"mm/dd/yyyy")),
			    "Not Applied"
			)
		lineageTag: 950abe12-d8d4-43a3-8b9a-1526193cf961

	measure dxm_PaymentPerTow =
			
			DIVIDE(
			    sum('agg agg_revenue_call_report_payments'[payment_amount]),
			    count('agg agg_revenue_call_report_payments'[CallNumber]),
			    0
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 6363fbb8-ec62-436f-8dd0-031e0946e608

	measure 'Completion Date Filters' =
			
			"Completion Date: " & IF(
			    ISFILTERED('agg agg_revenue_call_report_payments'[Completion Date]),
			    CONCATENATE(min('agg agg_revenue_call_report_payments'[Completion Date]), "-"&max('agg agg_revenue_call_report_payments'[Completion Date])),
			    "Not Applied"
			)
		lineageTag: 56f3fd47-8d90-4439-b478-a673b4035479

	measure 'Payment Date Filters' =
			
