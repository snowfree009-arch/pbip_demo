	column 'Payment Week' = ```
			
			VAR StartOfWeek = 'agg agg_revenue_call_report_payments'[Payment Date] - WEEKDAY('agg agg_revenue_call_report_payments'[Payment Date], 2) + 1
			VAR EndOfWeek = StartOfWeek + 6
			RETURN 
			    FORMAT(StartOfWeek, "MM/DD") & " - " & FORMAT(EndOfWeek, "MM/DD")
			```
		lineageTag: 1896bb0f-62c1-461d-ba42-86cad0199d28
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

