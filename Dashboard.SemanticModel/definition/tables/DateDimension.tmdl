	partition DateDimension = calculated
		mode: import
		source = ```
				
				VAR StartDate = DATE(2024, 1, 1)
				VAR EndDate = TODAY()-1
				VAR DateTable = 
				    ADDCOLUMNS(
				        CALENDAR(StartDate, EndDate),
				        "Year", YEAR([Date]),
				        "Month", FORMAT([Date], "MMMM"),
				        "Month Number", MONTH([Date]),
				        "Day", DAY([Date]),
				        "Date Day", (FORMAT([Date],"MM/dd/yy")&" "&format([Date],"ddd")),
				        "Day of Week", FORMAT([Date], "dddd"),
				        "Day of Week Number", WEEKDAY([Date], 1),
				        "Quarter", "Q" & FORMAT([Date], "Q"),
				        "Is Weekday", IF(WEEKDAY([Date], 2) <= 5, TRUE(), FALSE())
				    )
				RETURN
				    DateTable
				
				```

	annotation PBI_Id = b59768f7937f44dab9b4fcce1b036b71

