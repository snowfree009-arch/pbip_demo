	column Call_Status = ```
			IF('agg_revenue_call_report'[is_impounded] = "yes"
			                    && 'agg_revenue_call_report'[Lock Status] = "yes" 
			                    && 'agg_revenue_call_report'[Audit Status] = "yes" 
			                    && 'agg_revenue_call_report'[released] = "yes"
			                    , "Closed", 
			                    IF('agg_revenue_call_report'[is_impounded] = "no"
			                    && 'agg_revenue_call_report'[Lock Status] = "yes" 
			                    && 'agg_revenue_call_report'[Audit Status] = "yes" 
			                    && 'agg_revenue_call_report'[released] = "no",
			                    "Closed", "Open"
			                    )
			                )
			```
		lineageTag: 34a321be-751f-4faf-8385-39e24c2492f0
		summarizeBy: none

