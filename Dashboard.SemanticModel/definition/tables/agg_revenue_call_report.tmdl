	measure call_type_Name =
			
			VAR SelectedValues = VALUES(agg_revenue_call_report[Call Type])
			VAR SelectedCount = COUNTROWS(SelectedValues)
			VAR TotalCount = COUNTROWS(ALL(agg_revenue_call_report[Call Type]))
			RETURN CONCATENATE("Call Type: ",
			    IF(
			        SelectedCount = 0 || SelectedCount = TotalCount,
			        "Standard Calls, Impound Calls",
			        IF(
			            SelectedCount = 1,
			            CONCATENATEX(SelectedValues, agg_revenue_call_report[Call Type], ", "),
			            CONCATENATEX(SelectedValues, agg_revenue_call_report[Call Type], ", ")
			        )
			    )
			)
		lineageTag: e2c2dc7d-ffbf-4f93-b71b-6c41340cdbc5

