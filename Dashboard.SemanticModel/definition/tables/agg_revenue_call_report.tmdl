	measure Revenue_by_Call_Type =
			
			IF(
			    SELECTEDVALUE(agg_revenue_call_report[Call Type]) = "Standard Calls",
			    CALCULATE(
			        SUM(agg_revenue_call_report[Total Generated Revenue]),
			        agg_revenue_call_report[is_impounded] = "no",
			        agg_revenue_call_report[is_audited] = "yes",
			        agg_revenue_call_report[is_locked] = "yes"
			    ),
			    IF(
			        SELECTEDVALUE(agg_revenue_call_report[Call Type]) = "Impounds",
			        CALCULATE(
			            SUM(agg_revenue_call_report[Payment Deposit]),
			            agg_revenue_call_report[is_impounded] = "yes"
			        )
			        ,0
			    )
			)
