	measure dxm_ImpountTrunaroundMinutes =
			
			VAR TotalImpoundCount = SUM(agg_revenue_call_report[Impound_count])
			VAR TotalImpoundDuration = SUM(agg_revenue_call_report[Impound_duration_min])
			RETURN
			IF(
			    (TotalImpoundCount < 0),
			    0,
			    (DIVIDE(TotalImpoundDuration, TotalImpoundCount, 0)/60)
			)
		lineageTag: c8220c9b-6208-476c-bbd2-2d331db1678b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure dxm_DispatchToOnsceneArrival =
			
			VAR Counts = COUNT(agg_revenue_call_report[call_id_sk])
			VAR Duration = SUM(agg_revenue_call_report[Disp_to_on_scene])
			RETURN
			IF(
			    (Counts <= 0),
			    0,
			    (DIVIDE(Duration, Counts, 0))
