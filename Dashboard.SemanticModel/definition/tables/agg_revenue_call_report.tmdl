	measure ImpoundTurnaroundTime = ```
			
			VAR TotalImpoundCount = SUM(agg_revenue_call_report[Impound_count])
			VAR TotalImpoundDuration = SUM(agg_revenue_call_report[Impound_duration_min])
			VAR ImpoundTurnaroundTimeMin = 
			    IF(
			        TotalImpoundCount < 0,
			        0,
			        DIVIDE(TotalImpoundDuration, TotalImpoundCount, 0)
			    )
			VAR Days = INT(ImpoundTurnaroundTimeMin / 1440)  // 1440 minutes in a day
			VAR RemainingMinutes = MOD(ImpoundTurnaroundTimeMin, 1440)
			VAR Hours = INT(RemainingMinutes / 60)
			VAR Minutes = MOD(RemainingMinutes, 60)
			RETURN
			IF(
			    SELECTEDVALUE(agg_revenue_call_report[is_impounded]) = "no", "Not Available",
			    FORMAT(Days, "00") & "d:" & FORMAT(Hours, "00") & "h:" & FORMAT(Minutes, "00") & "m"
			)
			```
		lineageTag: 142996b6-06a1-4d20-9b85-4842a3634c09

		formatStringDefinition = ""

