	column 'Age Category' =
			IF('agg_revenue_call_report'[Age] <= 30, "0-30 days",
			                    IF('agg_revenue_call_report'[Age] > 30 && 'agg_revenue_call_report'[Age] <= 60, "31-60 days",
			                        IF('agg_revenue_call_report'[Age] > 60 && 'agg_revenue_call_report'[Age] <= 90, "61-90 days",
			                            IF('agg_revenue_call_report'[Age] > 90 && 'agg_revenue_call_report'[Age] <=120, "90-120 days",
			                            "120+ days"
			                            )
			                        )
			                    )
