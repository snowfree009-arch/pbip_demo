			    SELECTEDVALUE(agg_revenue_call_report[is_impounded]) = "no", "Not Available",
			    FORMAT(Days, "00") & "d:" & FORMAT(Hours, "00") & "h:" & FORMAT(Minutes, "00") & "m"
			)
			```
		lineageTag: a806ff05-ecd5-4dff-8bcb-df8002b564b4

	measure 'opco last week avg impound duration' = ```
			
			VAR TotalImpoundCount = 
			CALCULATE(
			        SUM(agg_revenue_call_report[Impound_count]),
			        FILTER(
			            agg_revenue_call_report,
			            WEEKNUM('agg_revenue_call_report'[Tow Completion Date], 2) = WEEKNUM(TODAY()-7, 2) &&
			            YEAR('agg_revenue_call_report'[Tow Completion Date]) = YEAR(TODAY()-7)
			        )
			    )
			VAR TotalImpoundDuration = 
			    CALCULATE(
			        SUM(agg_revenue_call_report[Impound_duration_min]),
			        FILTER(
			            agg_revenue_call_report,
			            WEEKNUM('agg_revenue_call_report'[Tow Completion Date], 2) = WEEKNUM(TODAY()-7, 2) &&
			            YEAR('agg_revenue_call_report'[Tow Completion Date]) = YEAR(TODAY()-7)
			        )
			    )
			VAR ImpoundTurnaroundTimeMin = 
			    IF(
			        TotalImpoundCount < 0,
			        0,
			        DIVIDE(TotalImpoundDuration, TotalImpoundCount, 0)
			    )
			VAR Days = INT(ImpoundTurnaroundTimeMin / 1440)  // 1440 minutes in a day
			VAR RemainingMinutes = MOD(ImpoundTurnaroundTimeMin, 1440)
			VAR Hours = INT(RemainingMinutes / 60)
			VAR Minutes = MOD(RemainingMinutes, 60)
			RETURN
			IF(
			    SELECTEDVALUE(agg_revenue_call_report[is_impounded]) = "no", "Not Available",
			    FORMAT(Days, "00") & "d:" & FORMAT(Hours, "00") & "h:" & FORMAT(Minutes, "00") & "m"
			)
			```
		lineageTag: 843db187-2287-4356-aafd-06d41b9d0771

